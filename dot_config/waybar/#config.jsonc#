{
// Global settings
"position": "bottom",
"spacing": 4,
"reload_style_on_change": true,

// Module layout
"modules-left": [
"idle_inhibitor",
"niri/workspaces"
],

"modules-center": ["clock"],

"modules-right": [
"pulseaudio",
"pulseaudio/slider",
"backlight",
"backlight/slider",
"network",
"battery",
"upower"
],

// Modules configuration
"idle_inhibitor": {
"format": "{icon}",
"format-icons": {
"activated": "ΎΒχ",
"deactivated": "ΎΒ░"
}
},

"niri/workspaces": {
"disable-scroll": true,
"all-outputs": true,
"warp-on-scroll": false,
"format": "{icon}",
"format-icons": {
"urgent": "ΎΒς ",
"active": "ΎΗΤ ",
"default": "ΎΕΣ "
},
"persistent-workspaces": {
"1": [],
"2": [],
"3": []
}
},

"clock": {
"interval": 1,
"format": "<span size='12pt'>ΎΑΩ </span> {:%I:%M:%S %p}",
"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
"format-alt": "<span size='12pt'>ΎΒ│ </span> {:%Y-%m-%d}"
},

"pulseaudio": {
"format": "{volume}% <span size='12pt'>{icon}</span>",
"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
"format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
"format-muted": "<span size='12pt'>Όυν </span>{format_source}",
"format-source": "{volume}% <span size='12pt'>ΎΕ░</span>",
"format-source-muted": "ΎΕ▒ ",
"format-icons": {
"headphone": "ΎΑξ",
"headset": "ΎΨΡ",
"default": [
"ΎΑο",
"ΎΑπ",
"ΎΑρ"
]
}
},

"pulseaudio/slider": {
"min": 1,
"max": 80,
"orientation": "horizontal"
},

"backlight": {
"format": "{percent}% {icon}",
"format-icons": [
"ΎΕΣ",
"ΎΗΖ"
]
},

"backlight/slider": {
"min": 0,
"max": 100,
"orientation": "horizontal"
},

"network": {
"format-wifi": "ΎΘτ ",
"format-alt": "{essid}:{signalStrength}%",
"format-ethernet": "{ipaddr}/{cidr} Ό╜Ε ",
"tooltip-format": "{essid} ({signalStrength}%)",
"format-linked": "{ifname} (No IP) ΎηΨ",
"format-disconnected": "≤░νχ "
},

"upower": {
"show-icon": false,
"hide-if-empty": true,
"tooltip": true,
"tooltip-spacing": 20
},
"battery": {
"interval": 60,
"design-capacity": true,
"states": {
"warning": 40,
"critical": 30,
},
"format": "{icon}",
"format-icons": [
"<span size=\"13pt\">ΎΚΕ </span>",
"<span size='13pt'>ΎΚΔ </span>",
"<span size='13pt'>ΎΚΓ></span>",
"<span size='13pt'>ΎΚΒ </span>",
"<span size='13pt'>ΎΚΑ </span>"
],
"max-length": 25,
}
}
